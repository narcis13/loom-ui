{
  "$schema": "https://loom.dev/manifest.schema.json",
  "name": "checkbox",
  "version": "1.0.0",
  "kind": "primitive",
  "category": "forms",
  "description": "Checkbox input with token-based accent and focus styling",
  "anatomy": {
    "tag": "input",
    "selector": "[data-ui='checkbox']",
    "content_model": "text"
  },
  "states": {
    "unchecked": {
      "attr": "data-state=\"unchecked\"",
      "default": true
    },
    "checked": {
      "attr": "checked"
    },
    "disabled": {
      "attr": "disabled"
    }
  },
  "a11y": {
    "required_attrs": [
      "pair with a visible label or aria-label"
    ],
    "keyboard": {
      "Space": "toggle checkbox"
    }
  },
  "tokens_used": [
    "color-bg-elevated",
    "color-bg-muted",
    "color-bg-subtle",
    "color-fg",
    "color-fg-muted",
    "color-fg-subtle",
    "color-primary",
    "color-primary-fg",
    "color-primary-hover",
    "color-primary-subtle",
    "color-secondary",
    "color-secondary-hover",
    "color-secondary-fg",
    "color-border",
    "color-border-strong",
    "color-ring",
    "space-0",
    "space-px",
    "space-1",
    "space-2",
    "space-2h",
    "space-3",
    "space-4",
    "space-5",
    "space-6",
    "space-8",
    "text-xs",
    "text-sm",
    "text-base",
    "text-lg",
    "text-xl",
    "leading-tight",
    "leading-normal",
    "leading-relaxed",
    "weight-medium",
    "weight-semibold",
    "radius-sm",
    "radius-md",
    "radius-lg",
    "radius-xl",
    "radius-full",
    "shadow-xs",
    "shadow-sm",
    "shadow-md",
    "shadow-lg",
    "shadow-xl",
    "surface-radius",
    "surface-shadow",
    "dialog-radius",
    "dialog-shadow",
    "dialog-overlay-bg",
    "input-height",
    "input-radius",
    "input-border",
    "duration-fast",
    "duration-normal",
    "duration-slow",
    "ease-default",
    "ease-out",
    "z-dropdown",
    "z-overlay",
    "z-modal",
    "z-toast"
  ],
  "templates": {
    "html": "<input data-ui=\"checkbox\" type=\"checkbox\" aria-label=\"{label}\" />"
  },
  "safe_transforms": [
    "toggle-checked-state",
    "toggle-disabled-state",
    "associate-label"
  ],
  "unsafe_transforms": [
    "remove-label-association",
    "change-input-type"
  ],
  "composition": {
    "contains": [],
    "used_in": [
      "settings-page",
      "crud-table"
    ]
  },
  "files": {
    "html": "checkbox.html",
    "css": "checkbox.css",
    "manifest": "checkbox.manifest.json"
  },
  "tests": [
    "renders-as-checkbox-input",
    "supports-checked-state",
    "supports-disabled-state"
  ]
}
