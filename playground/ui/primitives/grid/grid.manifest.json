{
  "$schema": "https://loom.dev/manifest.schema.json",
  "name": "grid",
  "version": "1.0.0",
  "kind": "primitive",
  "category": "layout",
  "description": "Responsive CSS grid helper with tokenized gaps and column counts",
  "anatomy": {
    "tag": "div",
    "selector": "[data-ui='grid']",
    "content_model": "block"
  },
  "variants": {
    "columns": {
      "values": [
        "2",
        "3",
        "4"
      ],
      "default": "2",
      "attr": "data-columns",
      "applied_to": "root"
    },
    "gap": {
      "values": [
        "sm",
        "md",
        "lg"
      ],
      "default": "md",
      "attr": "data-gap",
      "applied_to": "root"
    }
  },
  "tokens_used": [
    "color-bg-elevated",
    "color-bg-muted",
    "color-bg-subtle",
    "color-fg",
    "color-fg-muted",
    "color-fg-subtle",
    "color-primary",
    "color-primary-fg",
    "color-primary-hover",
    "color-primary-subtle",
    "color-secondary",
    "color-secondary-hover",
    "color-secondary-fg",
    "color-border",
    "color-border-strong",
    "color-ring",
    "space-0",
    "space-px",
    "space-1",
    "space-2",
    "space-2h",
    "space-3",
    "space-4",
    "space-5",
    "space-6",
    "space-8",
    "text-xs",
    "text-sm",
    "text-base",
    "text-lg",
    "text-xl",
    "leading-tight",
    "leading-normal",
    "leading-relaxed",
    "weight-medium",
    "weight-semibold",
    "radius-sm",
    "radius-md",
    "radius-lg",
    "radius-xl",
    "radius-full",
    "shadow-xs",
    "shadow-sm",
    "shadow-md",
    "shadow-lg",
    "shadow-xl",
    "surface-radius",
    "surface-shadow",
    "dialog-radius",
    "dialog-shadow",
    "dialog-overlay-bg",
    "input-height",
    "input-radius",
    "input-border",
    "duration-fast",
    "duration-normal",
    "duration-slow",
    "ease-default",
    "ease-out",
    "z-dropdown",
    "z-overlay",
    "z-modal",
    "z-toast"
  ],
  "templates": {
    "html": "<div data-ui=\"grid\" data-columns=\"{columns}\" data-gap=\"{gap}\">{children}</div>"
  },
  "safe_transforms": [
    "change-column-count",
    "change-gap",
    "reorder-children"
  ],
  "unsafe_transforms": [
    "hardcode-grid-gaps"
  ],
  "composition": {
    "contains": [],
    "used_in": [
      "dashboard-shell",
      "search-results"
    ]
  },
  "files": {
    "html": "grid.html",
    "css": "grid.css",
    "manifest": "grid.manifest.json"
  },
  "tests": [
    "renders-as-grid-container",
    "supports-column-variants",
    "supports-gap-variants"
  ]
}
