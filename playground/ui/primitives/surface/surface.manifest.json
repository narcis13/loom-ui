{
  "$schema": "https://loom.dev/manifest.schema.json",
  "name": "surface",
  "version": "1.0.0",
  "kind": "primitive",
  "category": "layout",
  "description": "Generic elevated container for grouping content without extra structure",
  "anatomy": {
    "tag": "div",
    "selector": "[data-ui='surface']",
    "content_model": "block"
  },
  "variants": {
    "tone": {
      "values": [
        "default",
        "muted",
        "primary"
      ],
      "default": "default",
      "attr": "data-variant",
      "applied_to": "root"
    }
  },
  "tokens_used": [
    "color-bg-elevated",
    "color-bg-muted",
    "color-bg-subtle",
    "color-fg",
    "color-fg-muted",
    "color-fg-subtle",
    "color-primary",
    "color-primary-fg",
    "color-primary-hover",
    "color-primary-subtle",
    "color-secondary",
    "color-secondary-hover",
    "color-secondary-fg",
    "color-border",
    "color-border-strong",
    "color-ring",
    "space-0",
    "space-px",
    "space-1",
    "space-2",
    "space-2h",
    "space-3",
    "space-4",
    "space-5",
    "space-6",
    "space-8",
    "text-xs",
    "text-sm",
    "text-base",
    "text-lg",
    "text-xl",
    "leading-tight",
    "leading-normal",
    "leading-relaxed",
    "weight-medium",
    "weight-semibold",
    "radius-sm",
    "radius-md",
    "radius-lg",
    "radius-xl",
    "radius-full",
    "shadow-xs",
    "shadow-sm",
    "shadow-md",
    "shadow-lg",
    "shadow-xl",
    "surface-radius",
    "surface-shadow",
    "dialog-radius",
    "dialog-shadow",
    "dialog-overlay-bg",
    "input-height",
    "input-radius",
    "input-border",
    "duration-fast",
    "duration-normal",
    "duration-slow",
    "ease-default",
    "ease-out",
    "z-dropdown",
    "z-overlay",
    "z-modal",
    "z-toast"
  ],
  "templates": {
    "html": "<div data-ui=\"surface\" data-variant=\"{variant}\">{content}</div>"
  },
  "safe_transforms": [
    "change-variant",
    "replace-content"
  ],
  "unsafe_transforms": [
    "remove-padding",
    "remove-border-without-replacement"
  ],
  "composition": {
    "contains": [],
    "used_in": [
      "empty-state",
      "dashboard-shell"
    ]
  },
  "files": {
    "html": "surface.html",
    "css": "surface.css",
    "manifest": "surface.manifest.json"
  },
  "tests": [
    "renders-as-elevated-container",
    "supports-tone-variants"
  ]
}
