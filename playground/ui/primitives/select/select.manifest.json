{
  "$schema": "https://loom.dev/manifest.schema.json",
  "name": "select",
  "version": "1.0.0",
  "kind": "primitive",
  "category": "forms",
  "description": "Native select element with token-based styling and validation states",
  "anatomy": {
    "tag": "select",
    "selector": "[data-ui='select']",
    "content_model": "text"
  },
  "variants": {
    "size": {
      "values": [
        "sm",
        "md",
        "lg"
      ],
      "default": "md",
      "attr": "data-size",
      "applied_to": "root"
    }
  },
  "states": {
    "default": {
      "attr": "data-state=\"default\"",
      "default": true
    },
    "invalid": {
      "attr": "data-state=\"invalid\""
    },
    "disabled": {
      "attr": "disabled"
    }
  },
  "a11y": {
    "required_attrs": [
      "label should be associated with the select element",
      "include an explicit default option when selection is required"
    ]
  },
  "tokens_used": [
    "input-height",
    "input-radius",
    "input-border",
    "color-bg-elevated",
    "color-bg-muted",
    "color-bg-subtle",
    "color-fg",
    "color-fg-muted",
    "color-fg-subtle",
    "color-primary",
    "color-primary-fg",
    "color-primary-hover",
    "color-primary-subtle",
    "color-secondary",
    "color-secondary-hover",
    "color-secondary-fg",
    "color-border",
    "color-border-strong",
    "color-ring",
    "space-0",
    "space-px",
    "space-1",
    "space-2",
    "space-2h",
    "space-3",
    "space-4",
    "space-5",
    "space-6",
    "space-8",
    "text-xs",
    "text-sm",
    "text-base",
    "text-lg",
    "text-xl",
    "leading-tight",
    "leading-normal",
    "leading-relaxed",
    "weight-medium",
    "weight-semibold",
    "radius-sm",
    "radius-md",
    "radius-lg",
    "radius-xl",
    "radius-full",
    "shadow-xs",
    "shadow-sm",
    "shadow-md",
    "shadow-lg",
    "shadow-xl",
    "surface-radius",
    "surface-shadow",
    "dialog-radius",
    "dialog-shadow",
    "dialog-overlay-bg",
    "input-height",
    "input-radius",
    "input-border",
    "duration-fast",
    "duration-normal",
    "duration-slow",
    "ease-default",
    "ease-out",
    "z-dropdown",
    "z-overlay",
    "z-modal",
    "z-toast"
  ],
  "templates": {
    "html": "<select data-ui=\"select\" data-size=\"{size}\"><option>{placeholder}</option><option>{option_1}</option><option>{option_2}</option></select>"
  },
  "safe_transforms": [
    "add-option",
    "remove-option",
    "change-size",
    "set-invalid-state"
  ],
  "unsafe_transforms": [
    "remove-label-association",
    "replace-with-non-form-element"
  ],
  "composition": {
    "contains": [],
    "used_in": [
      "settings-page",
      "auth-form"
    ]
  },
  "files": {
    "html": "select.html",
    "css": "select.css",
    "manifest": "select.manifest.json"
  },
  "tests": [
    "renders-as-select-element",
    "supports-size-variants",
    "invalid-state-uses-border-color"
  ]
}
