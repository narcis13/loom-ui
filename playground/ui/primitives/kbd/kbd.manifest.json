{
  "$schema": "https://loom.dev/manifest.schema.json",
  "name": "kbd",
  "version": "1.0.0",
  "kind": "primitive",
  "category": "typography",
  "description": "Keyboard shortcut token rendered in a compact monospace pill",
  "anatomy": {
    "tag": "kbd",
    "selector": "[data-ui='kbd']",
    "content_model": "inline"
  },
  "variants": {
    "size": {
      "values": [
        "sm",
        "md"
      ],
      "default": "md",
      "attr": "data-size",
      "applied_to": "root"
    }
  },
  "tokens_used": [
    "color-bg-elevated",
    "color-bg-muted",
    "color-bg-subtle",
    "color-fg",
    "color-fg-muted",
    "color-fg-subtle",
    "color-primary",
    "color-primary-fg",
    "color-primary-hover",
    "color-primary-subtle",
    "color-secondary",
    "color-secondary-hover",
    "color-secondary-fg",
    "color-border",
    "color-border-strong",
    "color-ring",
    "space-0",
    "space-px",
    "space-1",
    "space-2",
    "space-2h",
    "space-3",
    "space-4",
    "space-5",
    "space-6",
    "space-8",
    "text-xs",
    "text-sm",
    "text-base",
    "text-lg",
    "text-xl",
    "leading-tight",
    "leading-normal",
    "leading-relaxed",
    "weight-medium",
    "weight-semibold",
    "radius-sm",
    "radius-md",
    "radius-lg",
    "radius-xl",
    "radius-full",
    "shadow-xs",
    "shadow-sm",
    "shadow-md",
    "shadow-lg",
    "shadow-xl",
    "surface-radius",
    "surface-shadow",
    "dialog-radius",
    "dialog-shadow",
    "dialog-overlay-bg",
    "input-height",
    "input-radius",
    "input-border",
    "duration-fast",
    "duration-normal",
    "duration-slow",
    "ease-default",
    "ease-out",
    "z-dropdown",
    "z-overlay",
    "z-modal",
    "z-toast"
  ],
  "templates": {
    "html": "<kbd data-ui=\"kbd\" data-size=\"{size}\">{keys}</kbd>"
  },
  "safe_transforms": [
    "change-text-content",
    "change-size"
  ],
  "unsafe_transforms": [
    "replace-with-non-semantic-element"
  ],
  "composition": {
    "contains": [],
    "used_in": [
      "command-palette"
    ]
  },
  "files": {
    "html": "kbd.html",
    "css": "kbd.css",
    "manifest": "kbd.manifest.json"
  },
  "tests": [
    "renders-as-kbd-element",
    "supports-size-variants"
  ]
}
