{
  "$schema": "https://loom.dev/manifest.schema.json",
  "name": "command-palette",
  "version": "1.0.0",
  "kind": "recipe",
  "category": "overlay",
  "description": "Modal command launcher with search filtering and keyboard shortcut support",
  "anatomy": {
    "tag": "div",
    "selector": "[data-ui='command-palette']",
    "content_model": "slots"
  },
  "slots": {
    "trigger": {
      "selector": "[data-part='trigger']",
      "required": false,
      "tag_hint": "button"
    },
    "overlay": {
      "selector": "[data-part='overlay']",
      "required": true,
      "tag_hint": "div"
    },
    "panel": {
      "selector": "[data-part='panel']",
      "required": true,
      "tag_hint": "div"
    },
    "header": {
      "selector": "[data-part='header']",
      "required": true,
      "tag_hint": "div"
    },
    "title": {
      "selector": "[data-part='title']",
      "required": true,
      "tag_hint": "h2"
    },
    "input": {
      "selector": "[data-part='input']",
      "required": true,
      "tag_hint": "input"
    },
    "list": {
      "selector": "[data-part='list']",
      "required": true,
      "tag_hint": "div"
    },
    "item": {
      "selector": "[data-part='item']",
      "required": true,
      "tag_hint": "button"
    },
    "close": {
      "selector": "[data-part='close']",
      "required": false,
      "tag_hint": "button"
    }
  },
  "states": {
    "closed": {
      "attr": "data-state=\"closed\"",
      "default": true
    },
    "open": {
      "attr": "data-state=\"open\""
    },
    "closing": {
      "attr": "data-state=\"closing\"",
      "transient": true
    }
  },
  "a11y": {
    "role": "dialog",
    "aria-modal": true,
    "required_attrs": [
      "aria-labelledby linked to title",
      "role=\"listbox\" on result list"
    ],
    "focus_trap": true,
    "escape_closes": true,
    "return_focus": "trigger",
    "keyboard": {
      "Meta+K / Ctrl+K": "open palette",
      "ArrowDown": "move to next command",
      "Enter": "run active command"
    }
  },
  "tokens_used": [
    "color-bg-elevated",
    "color-bg-muted",
    "color-bg-subtle",
    "color-fg",
    "color-fg-muted",
    "color-fg-subtle",
    "color-primary",
    "color-primary-fg",
    "color-primary-hover",
    "color-primary-subtle",
    "color-secondary",
    "color-secondary-hover",
    "color-secondary-fg",
    "color-border",
    "color-border-strong",
    "color-ring",
    "space-0",
    "space-px",
    "space-1",
    "space-2",
    "space-2h",
    "space-3",
    "space-4",
    "space-5",
    "space-6",
    "space-8",
    "text-xs",
    "text-sm",
    "text-base",
    "text-lg",
    "text-xl",
    "leading-tight",
    "leading-normal",
    "leading-relaxed",
    "weight-medium",
    "weight-semibold",
    "radius-sm",
    "radius-md",
    "radius-lg",
    "radius-xl",
    "radius-full",
    "shadow-xs",
    "shadow-sm",
    "shadow-md",
    "shadow-lg",
    "shadow-xl",
    "surface-radius",
    "surface-shadow",
    "dialog-radius",
    "dialog-shadow",
    "dialog-overlay-bg",
    "input-height",
    "input-radius",
    "input-border",
    "duration-fast",
    "duration-normal",
    "duration-slow",
    "ease-default",
    "ease-out",
    "z-dropdown",
    "z-overlay",
    "z-modal",
    "z-toast"
  ],
  "templates": {
    "html": "<div data-ui=\"command-palette\" data-state=\"closed\" id=\"{id}\">\n  <div data-part=\"overlay\" hidden></div>\n  <div data-part=\"panel\" role=\"dialog\" aria-modal=\"true\" aria-labelledby=\"{id}-title\" hidden tabindex=\"-1\">\n    <div data-part=\"header\">\n      <h2 id=\"{id}-title\" data-part=\"title\">{title}</h2>\n      <button data-part=\"close\" type=\"button\" aria-label=\"Close command palette\">Close</button>\n    </div>\n    <input data-ui=\"input\" data-part=\"input\" type=\"text\" />\n    <div data-part=\"list\" role=\"listbox\">\n      <button data-part=\"item\" type=\"button\">{command}</button>\n    </div>\n  </div>\n</div>"
  },
  "safe_transforms": [
    "change-command-list",
    "change-placeholder",
    "customize-empty-state"
  ],
  "unsafe_transforms": [
    "remove-focus-trap",
    "remove-hotkey-without-replacement"
  ],
  "composition": {
    "contains": [
      "input"
    ],
    "used_in": [
      "dashboard-shell"
    ]
  },
  "files": {
    "html": "command-palette.html",
    "css": "command-palette.css",
    "js": "command-palette.js",
    "manifest": "command-palette.manifest.json"
  },
  "tests": [
    "opens-on-hotkey",
    "filters-commands",
    "closes-on-escape"
  ]
}
