{
  "$schema": "https://loom.dev/manifest.schema.json",
  "name": "tooltip",
  "version": "1.0.0",
  "kind": "recipe",
  "category": "overlay",
  "description": "Informational tooltip that opens on hover and focus",
  "anatomy": {
    "tag": "span",
    "selector": "[data-ui='tooltip']",
    "content_model": "slots"
  },
  "slots": {
    "trigger": {
      "selector": "[data-part='trigger']",
      "required": true,
      "tag_hint": "button"
    },
    "content": {
      "selector": "[data-part='content']",
      "required": true,
      "tag_hint": "div"
    }
  },
  "states": {
    "closed": {
      "attr": "data-state=\"closed\"",
      "default": true
    },
    "open": {
      "attr": "data-state=\"open\""
    }
  },
  "a11y": {
    "role": "tooltip",
    "required_attrs": [
      "aria-describedby linking the trigger to tooltip content"
    ],
    "keyboard": {
      "Escape": "dismiss tooltip"
    }
  },
  "tokens_used": [
    "color-bg-elevated",
    "color-bg-muted",
    "color-bg-subtle",
    "color-fg",
    "color-fg-muted",
    "color-fg-subtle",
    "color-primary",
    "color-primary-fg",
    "color-primary-hover",
    "color-primary-subtle",
    "color-secondary",
    "color-secondary-hover",
    "color-secondary-fg",
    "color-border",
    "color-border-strong",
    "color-ring",
    "space-0",
    "space-px",
    "space-1",
    "space-2",
    "space-2h",
    "space-3",
    "space-4",
    "space-5",
    "space-6",
    "space-8",
    "text-xs",
    "text-sm",
    "text-base",
    "text-lg",
    "text-xl",
    "leading-tight",
    "leading-normal",
    "leading-relaxed",
    "weight-medium",
    "weight-semibold",
    "radius-sm",
    "radius-md",
    "radius-lg",
    "radius-xl",
    "radius-full",
    "shadow-xs",
    "shadow-sm",
    "shadow-md",
    "shadow-lg",
    "shadow-xl",
    "surface-radius",
    "surface-shadow",
    "dialog-radius",
    "dialog-shadow",
    "dialog-overlay-bg",
    "input-height",
    "input-radius",
    "input-border",
    "duration-fast",
    "duration-normal",
    "duration-slow",
    "ease-default",
    "ease-out",
    "z-dropdown",
    "z-overlay",
    "z-modal",
    "z-toast"
  ],
  "templates": {
    "html": "<span data-ui=\"tooltip\" data-state=\"closed\" id=\"{id}\">\n  <button data-part=\"trigger\" type=\"button\" aria-describedby=\"{id}-content\">?</button>\n  <div data-part=\"content\" id=\"{id}-content\" role=\"tooltip\" hidden>{content}</div>\n</span>"
  },
  "safe_transforms": [
    "change-copy",
    "change-placement-via-custom-css"
  ],
  "unsafe_transforms": [
    "remove-aria-describedby",
    "remove-hidden-state-management"
  ],
  "composition": {
    "contains": [],
    "used_in": [
      "dashboard-shell"
    ]
  },
  "files": {
    "html": "tooltip.html",
    "css": "tooltip.css",
    "js": "tooltip.js",
    "manifest": "tooltip.manifest.json"
  },
  "tests": [
    "opens-on-hover",
    "opens-on-focus",
    "closes-on-escape"
  ]
}
