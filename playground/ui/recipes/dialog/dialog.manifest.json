{
  "$schema": "https://loom.dev/manifest.schema.json",
  "name": "dialog",
  "version": "1.0.0",
  "kind": "recipe",
  "category": "overlay",
  "description": "Modal dialog with overlay backdrop, focus trap, and escape-to-close handling",
  "anatomy": {
    "tag": "div",
    "selector": "[data-ui='dialog']",
    "content_model": "slots"
  },
  "slots": {
    "trigger": {
      "selector": "[data-part='trigger']",
      "required": true,
      "tag_hint": "button",
      "description": "Button that opens the dialog"
    },
    "overlay": {
      "selector": "[data-part='overlay']",
      "required": true,
      "tag_hint": "div",
      "description": "Backdrop that closes the dialog when clicked"
    },
    "panel": {
      "selector": "[data-part='panel']",
      "required": true,
      "tag_hint": "div",
      "description": "Dialog surface containing the interactive content"
    },
    "header": {
      "selector": "[data-part='header']",
      "required": false,
      "tag_hint": "div",
      "description": "Optional heading region that groups title and dismiss actions"
    },
    "title": {
      "selector": "[data-part='title']",
      "required": true,
      "tag_hint": "h2",
      "description": "Heading linked to the panel via aria-labelledby"
    },
    "description": {
      "selector": "[data-part='description']",
      "required": false,
      "tag_hint": "p",
      "description": "Optional supporting copy linked by aria-describedby"
    },
    "body": {
      "selector": "[data-part='body']",
      "required": true,
      "tag_hint": "div"
    },
    "footer": {
      "selector": "[data-part='footer']",
      "required": false,
      "tag_hint": "div",
      "description": "Optional action row for secondary and primary actions"
    },
    "close": {
      "selector": "[data-part='close']",
      "required": true,
      "tag_hint": "button",
      "description": "Button that closes the dialog"
    }
  },
  "variants": {
    "size": {
      "values": ["sm", "md", "lg", "full"],
      "default": "md",
      "attr": "data-size",
      "applied_to": "panel"
    }
  },
  "states": {
    "closed": {
      "attr": "data-state=\"closed\"",
      "default": true
    },
    "open": {
      "attr": "data-state=\"open\""
    },
    "closing": {
      "attr": "data-state=\"closing\"",
      "transient": true
    }
  },
  "a11y": {
    "role": "dialog",
    "aria-modal": true,
    "required_attrs": [
      "role=\"dialog\" on panel",
      "aria-modal=\"true\" on panel",
      "aria-labelledby pointing to title id",
      "aria-describedby pointing to description id when present",
      "aria-label on icon-only close buttons"
    ],
    "focus_trap": true,
    "escape_closes": true,
    "return_focus": "trigger",
    "keyboard": {
      "Escape": "close dialog",
      "Tab": "cycle focus within panel",
      "Shift+Tab": "cycle focus backward within panel"
    }
  },
  "tokens_used": [
    "dialog-radius",
    "dialog-shadow",
    "dialog-overlay-bg",
    "color-bg-elevated",
    "color-border",
    "color-fg",
    "color-fg-muted",
    "space-px",
    "space-2",
    "space-3",
    "space-4",
    "space-5",
    "space-6",
    "space-8",
    "text-sm",
    "text-xl",
    "weight-semibold",
    "leading-snug",
    "leading-relaxed",
    "duration-normal",
    "ease-default",
    "ease-out",
    "z-overlay",
    "z-modal"
  ],
  "templates": {
    "html": "<div data-ui=\"dialog\" data-state=\"closed\" id=\"{id}\">\n  <button data-ui=\"button\" data-part=\"trigger\" data-variant=\"primary\" type=\"button\">{trigger_text}</button>\n  <div data-part=\"overlay\" hidden></div>\n  <div data-part=\"panel\" id=\"{id}-panel\" role=\"dialog\" aria-modal=\"true\" aria-labelledby=\"{id}-title\" aria-describedby=\"{id}-description\" data-size=\"md\" hidden tabindex=\"-1\">\n    <div data-part=\"header\">\n      <div>\n        <h2 id=\"{id}-title\" data-part=\"title\">{title}</h2>\n        <p id=\"{id}-description\" data-part=\"description\">{description}</p>\n      </div>\n      <button data-part=\"close\" type=\"button\" aria-label=\"Close dialog\">Close</button>\n    </div>\n    <div data-part=\"body\">{body}</div>\n    <div data-part=\"footer\">\n      <button data-ui=\"button\" data-part=\"close\" data-variant=\"secondary\" type=\"button\" aria-label=\"Close dialog\">Cancel</button>\n      <button data-ui=\"button\" data-variant=\"primary\" type=\"button\">Continue</button>\n    </div>\n  </div>\n</div>"
  },
  "safe_transforms": [
    "change-size",
    "replace-body-content",
    "customize-overlay-opacity",
    "customize-footer-actions",
    "add-form-fields"
  ],
  "unsafe_transforms": [
    "remove-focus-trap",
    "remove-escape-handler",
    "remove-overlay",
    "remove-aria-labelledby",
    "change-panel-role"
  ],
  "composition": {
    "contains": ["button"],
    "used_in": ["settings-page", "crud-table"]
  },
  "files": {
    "html": "dialog.html",
    "css": "dialog.css",
    "js": "dialog.js",
    "manifest": "dialog.manifest.json"
  },
  "tests": [
    "opens-on-trigger-click",
    "closes-on-overlay-click",
    "closes-on-escape",
    "returns-focus-to-trigger",
    "traps-focus-while-open"
  ]
}
