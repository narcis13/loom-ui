{
  "name": "checkbox",
  "version": "1.0.0",
  "kind": "primitive",
  "category": "forms",
  "description": "Custom styled checkbox with checked, indeterminate, disabled states and size variants",

  "anatomy": {
    "tag": "input",
    "selector": "[data-ui='checkbox']",
    "content_model": "inline"
  },

  "slots": {
    "label": {
      "selector": "[data-part='label']",
      "required": false,
      "tag_hint": "span",
      "description": "Text label displayed next to the checkbox"
    }
  },

  "variants": {
    "size": {
      "values": ["sm", "md", "lg"],
      "default": "md",
      "attr": "data-size",
      "applied_to": "root"
    }
  },

  "states": {
    "default": { "attr": "data-state=\"default\"", "default": true },
    "checked": { "attr": "checked" },
    "indeterminate": { "attr": "data-state=\"indeterminate\"" },
    "disabled": { "attr": "disabled" }
  },

  "a11y": {
    "required_attrs": [
      "must be wrapped in label or have aria-label",
      "type=\"checkbox\" required on input element"
    ],
    "keyboard": {
      "Tab": "focus checkbox",
      "Space": "toggle checked state"
    }
  },

  "tokens_used": [
    "color-bg", "color-fg", "color-primary", "color-primary-fg",
    "color-border", "color-border-strong", "color-ring",
    "radius-sm", "space-1", "space-2",
    "duration-fast", "ease-default"
  ],

  "templates": {
    "html": "<label data-ui=\"checkbox-label\">\n  <input data-ui=\"checkbox\" type=\"checkbox\">\n  <span data-part=\"label\">{label}</span>\n</label>"
  },

  "safe_transforms": [
    "change-size",
    "toggle-checked",
    "toggle-disabled",
    "set-indeterminate",
    "change-label-text"
  ],

  "unsafe_transforms": [
    "remove-input-element",
    "remove-label-wrapper",
    "change-type-attribute"
  ],

  "composition": {
    "contains": [],
    "used_in": ["settings-page", "crud-table"]
  },

  "files": {
    "html": "checkbox.html",
    "css": "checkbox.css",
    "manifest": "checkbox.manifest.json"
  },

  "tests": [
    "renders-as-input-checkbox",
    "checked-state-shows-checkmark",
    "indeterminate-state-shows-dash",
    "disabled-state-has-disabled-attribute",
    "sm-size-sets-data-size-sm",
    "wrapped-in-label-for-accessibility",
    "native-appearance-is-none"
  ]
}
