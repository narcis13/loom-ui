{
  "name": "select",
  "version": "1.0.0",
  "kind": "primitive",
  "category": "forms",
  "description": "Native select dropdown with custom arrow, error and disabled states, and size variants",

  "anatomy": {
    "tag": "select",
    "selector": "[data-ui='select']",
    "content_model": "inline"
  },

  "slots": {},

  "variants": {
    "size": {
      "values": ["sm", "md", "lg"],
      "default": "md",
      "attr": "data-size",
      "applied_to": "root"
    }
  },

  "states": {
    "default": { "attr": "data-state=\"default\"", "default": true },
    "error": { "attr": "data-state=\"error\"" },
    "disabled": { "attr": "disabled" }
  },

  "a11y": {
    "required_attrs": [
      "aria-invalid=\"true\" when in error state",
      "id + matching label[for] for accessibility"
    ],
    "keyboard": {
      "Tab": "focus select",
      "Space": "open dropdown",
      "ArrowUp/ArrowDown": "navigate options",
      "Enter": "select option"
    }
  },

  "tokens_used": [
    "color-bg", "color-fg", "color-fg-muted",
    "color-border", "color-border-strong", "color-ring", "color-destructive",
    "radius-md", "space-2", "space-3", "space-4",
    "font-sans", "text-xs", "text-sm", "text-base",
    "duration-fast", "ease-default"
  ],

  "templates": {
    "html": "<select data-ui=\"select\">\n  <option value=\"\">{placeholder}</option>\n</select>"
  },

  "safe_transforms": [
    "change-size",
    "add-option",
    "remove-option",
    "set-default-option"
  ],

  "unsafe_transforms": [
    "remove-select-element",
    "change-to-div-without-role"
  ],

  "composition": {
    "contains": [],
    "used_in": ["settings-page", "crud-table"]
  },

  "files": {
    "html": "select.html",
    "css": "select.css",
    "manifest": "select.manifest.json"
  },

  "tests": [
    "renders-as-select-element",
    "error-state-sets-data-state-error",
    "error-state-has-aria-invalid",
    "disabled-state-has-disabled-attribute",
    "sm-size-sets-data-size-sm",
    "native-appearance-is-none",
    "custom-arrow-is-visible"
  ]
}
