{
  "name": "kbd",
  "version": "1.0.0",
  "kind": "primitive",
  "category": "typography",
  "description": "Inline keyboard shortcut key indicator",

  "anatomy": {
    "tag": "kbd",
    "selector": "[data-ui='kbd']",
    "content_model": "text"
  },

  "slots": {},

  "variants": {},

  "states": {},

  "props": {
    "key": { "type": "string", "default": "", "description": "Key label text" }
  },

  "a11y": {
    "notes": "Uses semantic <kbd> element; no additional ARIA needed",
    "keyboard": {}
  },

  "tokens_used": [
    "color-bg-subtle", "color-fg", "color-border",
    "radius-sm",
    "space-1h",
    "font-mono", "text-xs"
  ],

  "templates": {
    "html": "<kbd data-ui=\"kbd\">{key}</kbd>",
    "html_combo": "<kbd data-ui=\"kbd\">{modifier}</kbd> + <kbd data-ui=\"kbd\">{key}</kbd>"
  },

  "safe_transforms": [
    "change-text-content"
  ],

  "unsafe_transforms": [
    "change-tag-from-kbd",
    "remove-semantic-element"
  ],

  "composition": {
    "contains": [],
    "used_in": ["command-palette"]
  },

  "files": {
    "html": "kbd.html",
    "css": "kbd.css",
    "manifest": "kbd.manifest.json"
  },

  "tests": [
    "renders-as-kbd-element",
    "has-monospace-font",
    "has-border-bottom-emphasis",
    "displays-inline-flex"
  ]
}
