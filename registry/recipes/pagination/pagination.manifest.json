{
  "name": "pagination",
  "version": "1.0.0",
  "kind": "recipe",
  "category": "navigation",
  "description": "Page navigation with numbered controls, previous/next, and ellipsis",

  "anatomy": {
    "tag": "div",
    "selector": "[data-ui='pagination']",
    "content_model": "slots"
  },

  "slots": {
    "nav": {
      "selector": "[data-part='nav']",
      "required": true,
      "tag_hint": "nav",
      "description": "Navigation container with role=navigation"
    },
    "prev": {
      "selector": "[data-part='prev']",
      "required": true,
      "tag_hint": "button",
      "description": "Previous page button"
    },
    "next": {
      "selector": "[data-part='next']",
      "required": true,
      "tag_hint": "button",
      "description": "Next page button"
    },
    "page": {
      "selector": "[data-part='page']",
      "required": true,
      "tag_hint": "button",
      "description": "Individual page number button"
    },
    "ellipsis": {
      "selector": "[data-part='ellipsis']",
      "required": false,
      "tag_hint": "span",
      "description": "Ellipsis indicator for skipped pages"
    }
  },

  "variants": {
    "size": {
      "values": ["sm", "md", "lg"],
      "default": "md",
      "attr": "data-size",
      "applied_to": "root"
    }
  },

  "states": {
    "default": { "attr": "", "default": true },
    "active": { "attr": "data-state=\"active\"", "applied_to": "page" }
  },

  "a11y": {
    "required_attrs": [
      "role=\"navigation\" on nav",
      "aria-label=\"Pagination\" on nav",
      "aria-current=\"page\" on active page button",
      "aria-label on prev button",
      "aria-label on next button"
    ],
    "keyboard": {
      "Enter/Space": "activate page button",
      "Tab": "navigate between controls"
    }
  },

  "tokens_used": [
    "color-bg", "color-bg-muted", "color-fg", "color-fg-muted",
    "color-primary", "color-primary-fg", "color-border",
    "radius-md", "space-1", "space-2", "space-3",
    "text-xs", "text-sm", "text-base", "weight-medium",
    "duration-fast", "ease-default"
  ],

  "templates": {
    "html": "<div data-ui=\"pagination\" data-size=\"{size}\">\n  <nav data-part=\"nav\" role=\"navigation\" aria-label=\"Pagination\">\n    <button data-part=\"prev\" aria-label=\"Previous page\">&laquo; Prev</button>\n    <button data-part=\"page\" data-page=\"1\" data-state=\"active\" aria-current=\"page\">1</button>\n    <button data-part=\"page\" data-page=\"2\">2</button>\n    <span data-part=\"ellipsis\">&hellip;</span>\n    <button data-part=\"page\" data-page=\"{total}\">{total}</button>\n    <button data-part=\"next\" aria-label=\"Next page\">Next &raquo;</button>\n  </nav>\n</div>"
  },

  "safe_transforms": [
    "change-size",
    "add-page-buttons",
    "remove-ellipsis",
    "restyle-active-page",
    "change-prev-next-text"
  ],

  "unsafe_transforms": [
    "remove-navigation-role",
    "remove-aria-current",
    "remove-aria-labels",
    "remove-disabled-state"
  ],

  "composition": {
    "contains": ["button"],
    "used_in": ["crud-table", "search-results"]
  },

  "files": {
    "html": "pagination.html",
    "css": "pagination.css",
    "js": "pagination.js",
    "manifest": "pagination.manifest.json"
  },

  "tests": [
    "clicking-page-button-activates-it",
    "clicking-next-advances-page",
    "clicking-prev-goes-back",
    "prev-disabled-on-first-page",
    "next-disabled-on-last-page",
    "emits-loom-page-change-event",
    "active-page-has-aria-current",
    "nav-has-role-navigation",
    "nav-has-aria-label",
    "prev-has-aria-label",
    "next-has-aria-label",
    "setPage-updates-active-state",
    "setTotal-updates-total-pages",
    "getPage-returns-current-page"
  ]
}
