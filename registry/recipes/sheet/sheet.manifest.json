{
  "name": "sheet",
  "version": "1.0.0",
  "kind": "recipe",
  "category": "overlay",
  "description": "Mobile-friendly bottom or side sheet that slides in from screen edge",

  "anatomy": {
    "tag": "div",
    "selector": "[data-ui='sheet']",
    "content_model": "slots"
  },

  "slots": {
    "trigger": {
      "selector": "[data-part='trigger']",
      "required": true,
      "tag_hint": "button",
      "description": "Button that opens the sheet"
    },
    "overlay": {
      "selector": "[data-part='overlay']",
      "required": true,
      "tag_hint": "div",
      "description": "Backdrop overlay, click to close"
    },
    "panel": {
      "selector": "[data-part='panel']",
      "required": true,
      "tag_hint": "div",
      "description": "The sheet panel container"
    },
    "header": {
      "selector": "[data-part='header']",
      "required": false,
      "tag_hint": "div",
      "description": "Header area containing title and close button"
    },
    "title": {
      "selector": "[data-part='title']",
      "required": true,
      "tag_hint": "h2",
      "description": "Linked via aria-labelledby to panel"
    },
    "body": {
      "selector": "[data-part='body']",
      "required": true,
      "tag_hint": "div",
      "description": "Scrollable content area"
    },
    "close": {
      "selector": "[data-part='close']",
      "required": true,
      "tag_hint": "button",
      "description": "Close button, must have aria-label"
    }
  },

  "variants": {
    "side": {
      "values": ["bottom", "top", "left", "right"],
      "default": "bottom",
      "attr": "data-variant",
      "applied_to": "panel"
    },
    "size": {
      "values": ["sm", "md", "lg"],
      "default": "md",
      "attr": "data-size",
      "applied_to": "panel"
    }
  },

  "states": {
    "closed": { "attr": "data-state=\"closed\"", "default": true },
    "open": { "attr": "data-state=\"open\"" },
    "closing": { "attr": "data-state=\"closing\"", "transient": true }
  },

  "a11y": {
    "role": "dialog",
    "aria-modal": true,
    "required_attrs": [
      "role=\"dialog\" on panel",
      "aria-modal=\"true\" on panel",
      "aria-labelledby pointing to title id",
      "aria-label on close button"
    ],
    "focus_trap": true,
    "escape_closes": true,
    "return_focus": "trigger",
    "keyboard": {
      "Escape": "close sheet",
      "Tab": "cycle focus within panel",
      "Shift+Tab": "reverse cycle focus within panel"
    }
  },

  "tokens_used": [
    "color-bg", "color-fg", "color-border",
    "shadow-xl", "radius-xl",
    "space-4", "space-6",
    "z-overlay", "z-modal",
    "duration-normal", "duration-slow", "ease-out"
  ],

  "templates": {
    "html": "<div data-ui=\"sheet\" data-state=\"closed\" id=\"{id}\">\n  <button data-part=\"trigger\">{trigger_text}</button>\n  <div data-part=\"overlay\" hidden></div>\n  <div data-part=\"panel\" data-variant=\"{side}\" data-size=\"{size}\" role=\"dialog\" aria-modal=\"true\" aria-labelledby=\"{id}-title\" hidden>\n    <div data-part=\"header\">\n      <h2 id=\"{id}-title\" data-part=\"title\">{title}</h2>\n      <button data-part=\"close\" aria-label=\"Close sheet\">\u2715</button>\n    </div>\n    <div data-part=\"body\">{body}</div>\n  </div>\n</div>"
  },

  "safe_transforms": [
    "change-variant-side",
    "change-variant-size",
    "restyle-panel-background",
    "add-content-to-body",
    "customize-overlay-opacity",
    "modify-border-radius",
    "swap-slide-animation"
  ],

  "unsafe_transforms": [
    "remove-focus-trap",
    "remove-escape-handler",
    "remove-aria-labelledby",
    "remove-overlay",
    "remove-close-button",
    "change-panel-role",
    "remove-aria-modal"
  ],

  "composition": {
    "contains": ["button"],
    "used_in": []
  },

  "files": {
    "html": "sheet.html",
    "css": "sheet.css",
    "js": "sheet.js",
    "manifest": "sheet.manifest.json"
  },

  "tests": [
    "opens-on-trigger-click",
    "closes-on-escape",
    "closes-on-overlay-click",
    "closes-on-close-button-click",
    "traps-focus-within-panel",
    "returns-focus-to-trigger-on-close",
    "sets-data-state-to-open-when-opened",
    "sets-data-state-to-closed-when-closed",
    "panel-has-role-dialog",
    "panel-has-aria-modal-true",
    "title-is-linked-via-aria-labelledby",
    "close-button-has-aria-label",
    "overlay-and-panel-are-hidden-when-closed",
    "bottom-variant-slides-from-bottom",
    "top-variant-slides-from-top",
    "left-variant-slides-from-left",
    "right-variant-slides-from-right",
    "size-sm-sets-correct-dimensions",
    "size-lg-sets-correct-dimensions"
  ]
}
